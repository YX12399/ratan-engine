  "interfaces": {
    "auto_discover": true,
    "routing_table_base": 100,
    "monitor_interval_sec": 5.0
  },
  "ai_optimizer": {
    "enabled": false,
    "interval_sec": 60,
    "model": "claude-sonnet-4-20250514",
    "rtt_target_ms": 100,
    "loss_target_pct": 2.0,
    "max_changes_per_cycle": 3
