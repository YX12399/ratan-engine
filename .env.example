# RATAN Engine Environment Variables
# Copy to .env and adjust for your deployment.

# ── Network ───────────────────────────────────────────────────────
# Server address for client mode (required in client mode)
RATAN_SERVER_ADDR=
# Ports
RATAN_API_PORT=8080
RATAN_DATA_PORT=9000
RATAN_PROBE_PORT=9001
RATAN_BIND_ADDR=0.0.0.0

# ── Client Mode ───────────────────────────────────────────────────
RATAN_CLIENT_ID=edge-01
RATAN_STARLINK_IFACE=wlan0
RATAN_CELLULAR_IFACE=wwan0

# ── Paths ─────────────────────────────────────────────────────────
RATAN_PROJECT_DIR=/root/ratan-engine
RATAN_CONFIG_PATH=config/defaults.json
RATAN_STATE_FILE=config/current_state.json
RATAN_LOG_FILE=logs/engine.log

# ── API / Service ─────────────────────────────────────────────────
RATAN_APP_VERSION=1.0.0
# Comma-separated list of allowed CORS origins ("*" for all)
RATAN_CORS_ORIGINS=*
RATAN_SERVICE_NAME=ratan-engine
RATAN_COMMAND_TIMEOUT=30

# ── AI ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
HYPERAGG_AI_MODEL=claude-sonnet-4-20250514

# ── HyperAgg v2 ──────────────────────────────────────────────────
HYPERAGG_VPS_HOST=
HYPERAGG_KEY=

# ── Deployment ────────────────────────────────────────────────────
# Target for deploy.sh (e.g., root@203.0.113.10)
RATAN_DEPLOY_TARGET=
RATAN_REMOTE_DIR=/root/ratan-engine
